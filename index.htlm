<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>Buendía Family Genealogy</title>
<style>
:root{--bg:#0b0d10;--text:#f4f7fb;--muted:#b8c0cc;--accent:#80ffb0;--gold:#ffd27d;--blue:#7eb8ff;--shadow:0 18px 60px rgba(0,0,0,.35);--radius:18px;--card-w:168px;}
*{box-sizing:border-box;}
body{margin:0;background:radial-gradient(circle at top left,rgba(128,255,176,.10),transparent 34%),radial-gradient(circle at bottom right,rgba(138,180,255,.11),transparent 38%),var(--bg);color:var(--text);font-family:Inter,ui-sans-serif,system-ui,-apple-system,sans-serif;min-height:100vh;}
header{padding:14px 20px 10px;border-bottom:1px solid rgba(255,255,255,.08);background:rgba(11,13,16,.82);backdrop-filter:blur(14px);position:sticky;top:0;z-index:20;}
.topbar{max-width:1500px;margin:0 auto;}
h1{margin:0;font-size:clamp(16px,2.6vw,26px);letter-spacing:-.03em;}
.subtitle{margin:3px 0 0;color:var(--muted);font-size:12px;}
main{max-width:1500px;margin:0 auto;padding:14px 20px 28px;}

/* ── Tree container: flex column, fixed height, owns the border/radius/shadow ── */
.tree-container{
  display:flex;flex-direction:column;height:80vh;
  border:1px solid rgba(255,255,255,.08);border-radius:var(--radius);
  box-shadow:var(--shadow);overflow:hidden;
}

/* ── Legend: flex-shrink:0 so it NEVER overlaps the canvas below it ── */
.legend{
  flex-shrink:0;display:flex;flex-direction:column;gap:0;
  padding:6px 12px;
  background:rgba(14,18,26,.98);
  backdrop-filter:blur(12px);
  border-bottom:1px solid rgba(255,255,255,.07);
}
.legend-row{display:flex;gap:5px;align-items:center;}
.legend-themes{border-top:1px solid rgba(255,255,255,.06);padding-top:5px;margin-top:4px;}
.legend-sep{width:1px;background:rgba(255,255,255,.14);align-self:stretch;margin:0 1px;}
.legend-label{color:var(--muted);font-size:9.5px;text-transform:uppercase;letter-spacing:.12em;padding:0 2px;}
.pill{display:inline-flex;align-items:center;gap:5px;color:var(--muted);background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.08);border-radius:999px;padding:4px 8px;font-size:10.5px;white-space:nowrap;}
.dot{width:6px;height:6px;border-radius:999px;flex-shrink:0;}
.filter-btn,.theme-btn{display:inline-flex;align-items:center;gap:4px;color:var(--muted);background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.11);border-radius:999px;padding:4px 9px;font-size:10.5px;white-space:nowrap;cursor:pointer;transition:background .15s,border .15s,color .15s;user-select:none;}
.filter-btn:hover,.theme-btn:hover{background:rgba(255,255,255,.10);color:var(--text);}
.filter-btn.active{color:#fff;background:rgba(255,255,255,.13);border-color:rgba(255,255,255,.32);}
#search{border-radius:999px;padding:4px 11px;font-size:11px;height:28px;width:140px;border:1px solid rgba(255,255,255,.12);background:rgba(255,255,255,.06);color:var(--text);outline:none;}
#resetLayoutBtn{padding:4px 11px;font-size:11px;height:28px;border-radius:999px;border:1px solid rgba(255,170,85,.5);background:rgba(255,255,255,.06);color:#ffbb77;cursor:pointer;}
#resetLayoutBtn:hover{background:rgba(255,170,85,.12);}

/* ── Canvas: flex:1 fills EXACTLY the remaining space, scroll lives here ── */
.canvas-wrap{
  flex:1;min-height:0;
  background:rgba(20,24,32,.72);
  overflow:auto;position:relative;cursor:grab;
}
.canvas-wrap.panning{cursor:grabbing !important;}

.tree{min-width:1200px;padding:20px 26px 60px;position:relative;}
.generation{display:grid;grid-template-columns:repeat(6,var(--card-w));gap:18px 22px;justify-content:center;margin:0 0 24px;}
.gen-title{grid-column:1/-1;color:var(--muted);font-size:11px;text-transform:uppercase;letter-spacing:.18em;margin:4px 0 -2px;text-align:center;}
.person{border:1px solid rgba(255,255,255,.10);background:linear-gradient(180deg,rgba(255,255,255,.075),rgba(255,255,255,.035));border-radius:16px;padding:11px;cursor:grab;position:relative;box-shadow:0 10px 28px rgba(0,0,0,.16);transition:border .15s,box-shadow .15s,opacity .15s;user-select:none;overflow:hidden;}
.person:hover{border-color:rgba(128,255,176,.35);z-index:20 !important;}
.person.selected{background:linear-gradient(180deg,rgba(128,255,176,.22),rgba(128,255,176,.10));border-color:rgba(128,255,176,.45);box-shadow:0 0 0 1px rgba(128,255,176,.2),0 16px 40px rgba(0,0,0,.28);}
.person.related{background:linear-gradient(180deg,rgba(138,180,255,.22),rgba(138,180,255,.10));border-color:rgba(138,180,255,.45);}
.person.dim{opacity:.22;}
.person.dragging{opacity:.94;box-shadow:0 28px 70px rgba(0,0,0,.6) !important;border-color:rgba(255,255,255,.3) !important;z-index:50 !important;cursor:grabbing !important;}
.card-top{display:flex;align-items:flex-start;gap:7px;margin:0 0 7px;}
.avatar-init{width:34px;height:34px;border-radius:50%;border:1.5px solid;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:10.5px;font-weight:700;letter-spacing:-.01em;}
.card-info{flex:1;min-width:0;}
.name{font-weight:750;font-size:12.5px;line-height:1.15;letter-spacing:-.01em;margin-bottom:3px;}
.role{color:var(--muted);font-size:10px;line-height:1.25;}
.note-btn{background:none;border:1px solid rgba(255,255,255,.1);border-radius:8px;padding:0;cursor:pointer;color:rgba(255,255,255,.28);transition:color .15s,border .15s,background .15s;flex-shrink:0;display:flex;align-items:center;justify-content:center;width:24px;height:24px;}
.note-btn svg{width:12px;height:12px;pointer-events:none;}
.note-btn:hover{color:rgba(255,210,125,.9);border-color:rgba(255,210,125,.4);background:rgba(255,210,125,.08);}
.badges{display:flex;flex-wrap:wrap;gap:3px;}
.badge{font-size:9.5px;color:#dce7f5;border:1px solid rgba(255,255,255,.10);background:rgba(255,255,255,.07);border-radius:999px;padding:2px 6px;}
.spouse-link{grid-column:span 2;display:grid;grid-template-columns:var(--card-w) 42px var(--card-w);align-items:center;}
.marriage-line{height:2px;background:linear-gradient(90deg,transparent,var(--gold),transparent);}

/* ── Popup ─────────────────────────────────────────────────── */
.popup-backdrop{position:fixed;inset:0;background:rgba(0,0,0,.62);backdrop-filter:blur(5px);z-index:99;}
.popup-backdrop.hidden,.char-popup.hidden{display:none;}
.char-popup{position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);width:min(580px,94vw);max-height:86vh;background:#12161f;border:1px solid rgba(255,255,255,.13);border-radius:22px;box-shadow:0 36px 90px rgba(0,0,0,.75);z-index:100;display:flex;flex-direction:column;overflow:hidden;}
.popup-hdr{display:flex;align-items:flex-start;justify-content:space-between;gap:14px;padding:20px 20px 16px;border-bottom:1px solid rgba(255,255,255,.08);background:linear-gradient(180deg,rgba(255,255,255,.04),transparent);}
.popup-hdr-left{display:flex;align-items:center;gap:13px;}
.popup-avatar{width:50px;height:50px;border-radius:50%;border:2px solid;display:flex;align-items:center;justify-content:center;font-size:15px;font-weight:800;letter-spacing:-.02em;flex-shrink:0;}
.popup-name{font-size:20px;font-weight:800;letter-spacing:-.03em;color:#f4f7fb;line-height:1.1;}
.popup-role{font-size:11.5px;color:var(--muted);margin-top:3px;}
.popup-gen{display:inline-block;border-radius:999px;padding:2px 8px;font-size:9.5px;font-weight:600;letter-spacing:.05em;margin-top:5px;}
.popup-close{background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.1);color:var(--muted);border-radius:999px;width:32px;height:32px;cursor:pointer;font-size:15px;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:background .15s,color .15s;}
.popup-close:hover{background:rgba(255,255,255,.14);color:var(--text);}
.popup-body{overflow-y:auto;padding:18px 20px 24px;display:flex;flex-direction:column;gap:15px;}
.popup-section h4{font-size:9.5px;text-transform:uppercase;letter-spacing:.2em;margin:0 0 7px;}
.popup-section p{font-size:13px;line-height:1.65;color:#d8e2f0;margin:0;}
.popup-section.arc h4{color:var(--accent);}
.popup-section.themes-sec h4{color:var(--blue);}
.popup-section.watch h4{color:var(--gold);}
.popup-section.rels h4{color:var(--muted);}
.popup-rel-group{margin-bottom:7px;}
.popup-rel-label{font-size:9px;text-transform:uppercase;letter-spacing:.15em;display:block;margin-bottom:4px;}
.popup-nav-btn{margin:2px 3px 2px 0;padding:4px 9px;border-radius:8px;font-size:11px;cursor:pointer;color:var(--text);transition:filter .12s;}
.popup-nav-btn:hover{filter:brightness(1.3);}
</style>
</head>
<body>
<header>
  <div class="topbar">
    <h1>Buendía Family Genealogy</h1>
    <p class="subtitle">One Hundred Years of Solitude · Click a card to highlight connections · 📄 opens character notes · Drag to rearrange · Esc to dismiss</p>
  </div>
</header>
<main>
  <!-- tree-container is a flex column: legend on top, canvas below. They can NEVER overlap. -->
  <div class="tree-container">
    <div class="legend">
      <div class="legend-row">
        <span class="pill"><span class="dot" style="background:#80ffb0"></span>Selected</span>
        <span class="pill"><span class="dot" style="background:#8ab4ff"></span>Related</span>
        <span class="pill" style="background:#ffd27d33;border-color:#ffd27d55;color:#ffd27d;font-weight:600;">Spouse</span>
        <span class="pill" style="background:#7eb8ff33;border-color:#7eb8ff55;color:#7eb8ff;font-weight:600;">Parent</span>
        <span class="pill" style="background:#c084fc33;border-color:#c084fc55;color:#c084fc;font-weight:600;">Child</span>
        <span class="pill" style="background:#ff8ab433;border-color:#ff8ab455;color:#ff8ab4;font-weight:600;">Lover</span>
        <span class="legend-sep"></span>
        <span class="legend-label">Connections</span>
        <span class="filter-btn" data-filter="blood">🩸 Blood</span>
        <span class="filter-btn" data-filter="romantic">💛 Romantic</span>
        <span class="filter-btn" data-filter="descend">👶 Descent</span>
        <span class="filter-btn" data-filter="unions">💍 Unions</span>
        <span class="legend-sep"></span>
        <input id="search" placeholder="Search…"/>
        <button id="resetLayoutBtn">Reset positions</button>
      </div>
      <div class="legend-row legend-themes">
        <span class="legend-label">Themes</span>
        <span class="theme-btn" data-theme="solitude">🔮 Solitude</span>
        <span class="theme-btn" data-theme="war">⚔️ War</span>
        <span class="theme-btn" data-theme="forbidden">💘 Forbidden love</span>
        <span class="theme-btn" data-theme="fate">🔄 Fate &amp; repetition</span>
        <span class="theme-btn" data-theme="magic">✨ Magic</span>
        <span class="theme-btn" data-theme="vitality">🌿 Vitality</span>
      </div>
    </div>
    <!-- canvas-wrap: flex:1, fills all space below legend, scroll lives here -->
    <div class="canvas-wrap">
      <div class="tree" id="tree">
        <div class="generation">
          <div class="gen-title">Founding Generation</div>
          <div class="spouse-link" style="grid-column:2/span 2;">
            <div class="person" data-id="jose-arcadio-buendia"></div>
            <div class="marriage-line"></div>
            <div class="person" data-id="ursula"></div>
          </div>
          <div class="person" data-id="melquiades" style="grid-column:5;"></div>
        </div>
        <div class="generation">
          <div class="gen-title">Children Raised in the Buendía House</div>
          <div class="person" data-id="jose-arcadio-son" style="grid-column:1;"></div>
          <div class="person" data-id="aureliano-colonel" style="grid-column:2;"></div>
          <div class="person" data-id="amaranta" style="grid-column:3;"></div>
          <div class="person" data-id="rebeca" style="grid-column:4;"></div>
          <div class="person" data-id="pilar" style="grid-column:5;"></div>
          <div class="person" data-id="remedios-moscote" style="grid-column:6;"></div>
        </div>
        <div class="generation">
          <div class="gen-title">Next Generation</div>
          <div class="person" data-id="arcadio" style="grid-column:2;"></div>
          <div class="person" data-id="santa-sofia" style="grid-column:3;"></div>
          <div class="person" data-id="aureliano-jose" style="grid-column:4;"></div>
          <div class="person" data-id="aurelianos-17" style="grid-column:5;"></div>
        </div>
        <div class="generation">
          <div class="gen-title">Later Buendías</div>
          <div class="person" data-id="remedios-beauty" style="grid-column:1;"></div>
          <div class="person" data-id="jose-arcadio-segundo" style="grid-column:2;"></div>
          <div class="person" data-id="aureliano-segundo" style="grid-column:3;"></div>
          <div class="person" data-id="fernanda" style="grid-column:4;"></div>
          <div class="person" data-id="petra" style="grid-column:5;"></div>
        </div>
        <div class="generation">
          <div class="gen-title">Final Generations</div>
          <div class="person" data-id="renata" style="grid-column:2;"></div>
          <div class="person" data-id="jose-arcadio-later" style="grid-column:3;"></div>
          <div class="person" data-id="amaranta-ursula" style="grid-column:4;"></div>
          <div class="person" data-id="mauricio" style="grid-column:5;"></div>
          <div class="person" data-id="aureliano-babilonia" style="grid-column:6;"></div>
        </div>
      </div>
    </div>
  </div>
</main>

<div class="popup-backdrop hidden" id="popup-backdrop"></div>
<div class="char-popup hidden" id="char-popup">
  <div class="popup-hdr">
    <div class="popup-hdr-left">
      <div class="popup-avatar" id="popup-avatar"></div>
      <div><div class="popup-name" id="popup-name"></div><div class="popup-role" id="popup-role"></div><div id="popup-gen"></div></div>
    </div>
    <button class="popup-close" id="popup-close">✕</button>
  </div>
  <div class="popup-body" id="popup-body"></div>
</div>

<script>
const COLORS={spouses:'#ffd27d',parents:'#7eb8ff',children:'#c084fc',lovers:'#ff8ab4'};
const REL_TYPES=['spouses','parents','children','lovers'];
const FILTER_TYPES={blood:['parents','children'],romantic:['spouses','lovers'],descend:['children'],unions:['spouses']};
const GEN_COLORS={
  "Founding generation":"#ffd27d","Outside time":"#e0b0ff",
  "Second generation":"#80ffb0","Second generation / adopted":"#80ffb0",
  "Second generation marriage connection":"#a8e8d8",
  "Macondo outsider":"#c4b5fd","Third generation":"#8ab4ff",
  "War generation":"#c084fc","Later generation":"#c084fc",
  "Later generation marriage connection":"#c084fc",
  "Final generations":"#ff8ab4","Final generation":"#ff8ab4",
  "Final generations connection":"#ffb4d0","Romantic connection":"#ffb4d0",
};
const THEMES={
  solitude:{label:"Solitude",col:"#8ab4ff",ids:new Set(["jose-arcadio-buendia","aureliano-colonel","amaranta","aureliano-babilonia","jose-arcadio-segundo","remedios-beauty","jose-arcadio-later","rebeca","melquiades"])},
  war:{label:"War",col:"#ff9a7a",ids:new Set(["aureliano-colonel","aurelianos-17","arcadio","aureliano-jose"])},
  forbidden:{label:"Forbidden love",col:"#ff8ab4",ids:new Set(["amaranta","rebeca","renata","amaranta-ursula","aureliano-babilonia","aureliano-jose","pietro-crespi"])},
  fate:{label:"Fate & repetition",col:"#c084fc",ids:new Set(["aurelianos-17","aureliano-babilonia","ursula","jose-arcadio-buendia","jose-arcadio-son","aureliano-colonel","melquiades"])},
  magic:{label:"Magic",col:"#ffd27d",ids:new Set(["remedios-beauty","mauricio","jose-arcadio-buendia","aureliano-babilonia","pilar","melquiades"])},
  vitality:{label:"Vitality",col:"#80ffb0",ids:new Set(["ursula","pilar","petra","aureliano-segundo","amaranta-ursula"])},
};
let activeFilter=null,activeTheme=null;

const people={
  "melquiades":{name:"Melquíades",role:"Gypsy sage; author of the prophetic manuscripts",gen:"Outside time",badges:["Sanskrit","Manuscripts","Beyond death"],parents:[],spouses:[],lovers:[],children:[],related:["jose-arcadio-buendia","aureliano-babilonia"],summary:"The gypsy who brings the outside world's wonders to Macondo and leaves behind parchments prophesying the Buendía family's entire history.",note:"He dies multiple times and keeps returning — he exists outside ordinary time.",
    notes:{arc:"First appears bringing magnets and ice to Macondo. He dies and returns repeatedly — García Márquez suggests he exists outside temporal logic. He eventually takes up residence in his room in the Buendía house and writes the manuscripts in Sanskrit, encoding the entire history of the family from beginning to apocalyptic end. His ghost later guides Aureliano Segundo toward the parchments.",themes:"The author figure within the story — Melquíades wrote the book we are reading. He represents the circular relationship between prophecy and narrative: if the future is already written, is it still the future? His manuscripts collapse the distinction between history and fate, between author and God.",watch:"Note that every discovery José Arcadio Buendía makes has already been documented by Melquíades. He is not a teacher — he is a mirror showing what will be discovered before it is discovered. The room he inhabits never ages while the rest of the house crumbles around it."}},
  "jose-arcadio-buendia":{name:"José Arcadio Buendía",role:"Patriarch; founder of Macondo",gen:"Founding generation",badges:["Founder","Alchemy","Obsession"],parents:[],spouses:["ursula"],lovers:[],children:["jose-arcadio-son","aureliano-colonel","amaranta"],related:["ursula","jose-arcadio-son","aureliano-colonel","amaranta","rebeca","melquiades"],summary:"Visionary founder of Macondo whose curiosity becomes all-consuming obsession.",note:"He begins as a civilizing force but becomes one of the first major examples of solitude through intellectual isolation.",
    notes:{arc:"Founds Macondo as a utopia of fresh beginning, then loses himself in successive obsessions — magnets, alchemy, the daguerreotype, astronomy — each promising total knowledge, each delivering only deeper isolation. He ends his life tied to a chestnut tree in the garden, speaking only in Latin, visited by the ghost of Prudencio Aguilar.",themes:"The tragedy of pure intellect divorced from human connection. His genius is real, but his inability to stop searching makes him Macondo's first prisoner of solitude — an explorer who can no longer return.",watch:"Notice how each obsession mirrors a stage of Macondo's own development. He is not mad — he is simply too early for the world he imagines. His chestnut tree becomes a kind of shrine that outlasts him."}},
  "ursula":{name:"Úrsula Iguarán",role:"Matriarch; practical center of the family",gen:"Founding generation",badges:["Matriarch","Longevity","Family order"],parents:[],spouses:["jose-arcadio-buendia"],lovers:[],children:["jose-arcadio-son","aureliano-colonel","amaranta"],related:["jose-arcadio-buendia","jose-arcadio-son","aureliano-colonel","amaranta","rebeca"],summary:"The novel's moral spine, outliving almost everyone across perhaps 115 years.",note:"Her fear of incest and malformed descendants becomes one of the novel's recurring hereditary anxieties.",
    notes:{arc:"Lives possibly 115–120 years, outlasting nearly everyone in the book. As her eyesight fails she develops an extraordinary inner map of the house — she 'sees' more blind than anyone else does with full sight. Her decline accelerates only when the house begins physically collapsing around her.",themes:"Practical wisdom, continuity, and the invisible labor that holds civilization together. She embodies everything the Buendía men destroy through their obsessions — and her tragedy is that she can see this happening but cannot stop it.",watch:"Track how she ages across the generations. Each time she is described she seems older and more remote, yet more perceptive. When she finally dies, the house begins its physical disintegration almost immediately."}},
  "jose-arcadio-son":{name:"José Arcadio",role:"Eldest son; physical, impulsive, erotic energy",gen:"Second generation",badges:["Runs away","Returns","Marries Rebeca"],parents:["jose-arcadio-buendia","ursula"],spouses:["rebeca"],lovers:["pilar"],children:["arcadio"],related:["rebeca","pilar","arcadio","ursula","jose-arcadio-buendia","aureliano-colonel","amaranta"],summary:"The eldest Buendía son who flees with the gypsies and returns transformed.",note:"His marriage to Rebeca is taboo — she was raised as his adoptive sister, though not biologically.",
    notes:{arc:"Leaves with the gypsies as a young man, returns with a body covered in tattoos and an overwhelming physical presence. He marries Rebeca over family objection. He is found dead with a gunshot wound — his blood runs through the house to find Úrsula — but who killed him and why is never resolved.",themes:"Raw physical appetite as the Buendía alternative to intellectual obsession. Both paths — intellect and body — lead to isolation, just through different corridors.",watch:"His mysterious death is deliberately unexplained. García Márquez treats cause and effect as optional in Macondo — some events simply occur and resist interpretation."}},
  "aureliano-colonel":{name:"Aureliano Buendía",role:"Second son; later Colonel Aureliano Buendía",gen:"Second generation",badges:["Solitary","32 civil wars","Little gold fish"],parents:["jose-arcadio-buendia","ursula"],spouses:["remedios-moscote"],lovers:["pilar"],children:["aurelianos-17","aureliano-jose"],related:["remedios-moscote","pilar","jose-arcadio-son","amaranta","jose-arcadio-buendia","ursula"],summary:"The most complex figure in the novel — soldier, lover, artist, and the epitome of solitude.",note:"His arc moves from private feeling to public war, then back into radical isolation.",
    notes:{arc:"Born with his eyes open, weeping in the womb. He fights 32 civil wars and loses all of them. He survives 14 assassination attempts, has 17 sons by 17 different women, and retreats finally into his workshop, endlessly making tiny gold fish — melting them down and starting over, never selling, never accumulating.",themes:"The hollowing cost of public life. The little gold fish are García Márquez's most precise image of futile, consoling repetition. War empties him of everything human, and he knows it.",watch:"The moment he orders the execution of his old friend Gerineldo Márquez — and then cancels it at the last second — is the pivot of his character. After that gesture of mercy, he withdraws completely."}},
  "amaranta":{name:"Amaranta",role:"Daughter; jealousy, refusal, deliberate solitude",gen:"Second generation",badges:["Pietro Crespi","Black bandage","Weaves her shroud"],parents:["jose-arcadio-buendia","ursula"],spouses:[],lovers:["pietro-crespi"],children:[],related:["rebeca","pietro-crespi","jose-arcadio-son","aureliano-colonel","ursula"],summary:"Defines herself through systematic refusal and self-punishment.",note:"Keep her distinct from Rebeca: Amaranta is associated with the most explicit jealous hostility.",
    notes:{arc:"Sabotages her own happiness from youth onward — manipulates Pietro Crespi away from Rebeca, then rejects him when he turns to her. She burns her own hand and wears a black bandage for life as self-punishment. She weaves her own burial shroud and calmly announces the date of her death, carrying letters to the dead as a trusted courier.",themes:"Self-inflicted solitude. Unlike other Buendías drawn outward by obsession, Amaranta turns every impulse toward love into an impulse toward refusal. She is not cruel by nature — she is terrified of happiness in a way she never fully understands.",watch:"Her relationship with her young nephew Aureliano José has an uncomfortable charge that García Márquez deliberately leaves ambiguous. The pattern — invite, then destroy — defines her entire emotional life."}},
  "rebeca":{name:"Rebeca",role:"Adopted outsider; earth-eater; mystery",gen:"Second generation / adopted",badges:["Earth-eating","Sack of bones","The great enigma"],parents:[],spouses:["jose-arcadio-son"],lovers:["pietro-crespi"],children:[],related:["jose-arcadio-son","amaranta","ursula","jose-arcadio-buendia","pietro-crespi"],summary:"Arrives with a sack of her parents' bones and a compulsion to eat earth — and remains the novel's greatest unresolved mystery.",note:"Her marriage to José Arcadio causes scandal because it violates the household's adopted-sibling structure.",
    notes:{arc:"Arrives as a child with a sack of bones and an uncontrollable habit of eating earth and plaster. Absorbed into the Buendía family, falls in love, marries José Arcadio over everyone's objection, is widowed mysteriously, and then simply withdraws from the narrative — alive but absent, in her shuttered house.",themes:"Radical outsiderhood that is never fully resolved. The earth she eats is mourning made physical — she literally consumes the ground.",watch:"She is the only major character whose fate is genuinely left open. García Márquez acknowledged he always meant to write her ending but never did. Her disappearance from the novel is itself a statement."}},
  "pilar":{name:"Pilar Ternera",role:"Lover, card-reader, mother, survivor",gen:"Macondo outsider",badges:["Cards","Two Buendía children","Century of presence"],parents:[],spouses:[],lovers:["jose-arcadio-son","aureliano-colonel"],children:["arcadio","aureliano-jose"],related:["jose-arcadio-son","aureliano-colonel","arcadio"],summary:"The novel's most durable figure — present in every generation as fortune-reader, lover, and archive of Macondo's erotic history.",note:"Not a Buendía by blood, but structurally central because she mothers Buendía descendants.",
    notes:{arc:"Appears in the novel's first pages as a young woman and is still alive in the final pages, so old she has lost count of her age, running a brothel. She has children by two Buendía men, reads fortunes in cards with striking accuracy, and serves as the erotic memory of the town across an entire century.",themes:"Acceptance, fatalism, and erotic vitality as a form of wisdom. She is everything the Buendía characters are not — comfortable with uncertainty, unbothered by impermanence, never destroyed by loss.",watch:"She reads the future accurately for everyone except herself. Her self-knowledge is perfect in a different register: she knows exactly what she is doing and why, while the Buendías she serves are almost entirely without self-knowledge."}},
  "remedios-moscote":{name:"Remedios Moscote",role:"Child-bride of Colonel Aureliano; portrait of innocence",gen:"Second generation marriage connection",badges:["Child marriage","Pre-political innocence","Aureliano's only grief"],parents:[],spouses:["aureliano-colonel"],lovers:[],children:[],related:["aureliano-colonel"],summary:"The child-bride whose brief life reshapes Colonel Aureliano's entire trajectory.",note:"Her death functions as a rupture in Aureliano's emotional life from which he never recovers.",
    notes:{arc:"Married to Aureliano as a young girl. She grows into her role with remarkable grace. She dies of a complicated miscarriage. Her death occupies barely a paragraph, but its emotional weight reverberates through every subsequent chapter about the Colonel.",themes:"Innocence caught between an old world of arranged marriage and the political violence entering Macondo. She is what Macondo loses when history arrives.",watch:"Compare her carefully to Remedios the Beauty — same name, same apparent innocence, completely different relationship to the world. The doubling is deliberate."}},
  "arcadio":{name:"Arcadio",role:"Son of José Arcadio and Pilar Ternera; petty tyrant",gen:"Third generation",badges:["Unknown parentage","Local authority","Firing squad"],parents:["jose-arcadio-son","pilar"],spouses:["santa-sofia"],lovers:[],children:["remedios-beauty","jose-arcadio-segundo","aureliano-segundo"],related:["jose-arcadio-son","pilar","santa-sofia","remedios-beauty","jose-arcadio-segundo","aureliano-segundo"],summary:"Raised without knowing his parents, he becomes a local authoritarian during the civil war period.",note:"Major bridge between the early family romance plot and the later political-authoritarian plot.",
    notes:{arc:"Grows up in the Buendía house without knowing his true parentage. When given local authority during the civil war he runs a petty tyranny with real cruelty. He is executed by firing squad. His final letters to Úrsula are the most tender writing in his section.",themes:"Orphaned identity producing authoritarian behavior. He shows how Buendía qualities — intensity, command, obsession — curdle into violence when stripped of grounding and family context.",watch:"His execution scene is emotionally precise. He thinks not of power or ideology but of Úrsula. The detail grounds the entire sequence in human grief rather than political drama."}},
  "santa-sofia":{name:"Santa Sofía de la Piedad",role:"Arcadio's partner; silent sustainer of the household",gen:"Third generation",badges:["Invisible labor","Generational endurance","Silent departure"],parents:[],spouses:["arcadio"],lovers:[],children:["remedios-beauty","jose-arcadio-segundo","aureliano-segundo"],related:["arcadio"],summary:"Works in the Buendía household for decades without a single scene of complaint or ambition.",note:"Her invisibility is a structural critique — García Márquez makes the erasure of her labor the point.",
    notes:{arc:"Works in the Buendía household across multiple generations without a single scene foregrounding her inner life. She eventually walks out one day, quietly, and simply never returns. Her departure is noted in one sentence. No one goes to find her.",themes:"The erasure of women's sustaining labor. Her lack of interiority in the narrative is not García Márquez failing to write her — it is García Márquez writing the condition of her erasure.",watch:"Count how many meals she prepares, children she raises, catastrophes she quietly absorbs. She is the infrastructure on which Macondo runs."}},
  "aureliano-jose":{name:"Aureliano José",role:"Son of Colonel Aureliano and Pilar Ternera",gen:"Third generation",badges:["War as displacement","Aunt Amaranta","Ambush death"],parents:["aureliano-colonel","pilar"],spouses:[],lovers:[],children:[],related:["aureliano-colonel","pilar","amaranta"],summary:"Develops a consuming attachment to his aunt Amaranta, joins the war as displacement, and is killed in an ambush.",note:"His arc is the novel's most compressed version of the Buendía male pattern: obsession, futile action, death.",
    notes:{arc:"Son of Colonel Aureliano and Pilar Ternera. Develops an intense attachment to his aunt Amaranta during the years of the colonel's wars — Amaranta initially encourages this and then abruptly, permanently refuses it. He joins the war partly as a displacement activity, and is killed in an ambush, dying in a stranger's arms.",themes:"Desire displaced by war, desire refused by family, desire finally cut short by violence. His arc is the novel's most compressed version of the Buendía male pattern.",watch:"He illuminates Amaranta by being one of several people whose love she both invites and destroys. The pattern — encourage, then refuse — seems systematic in her, not personal."}},
  "aurelianos-17":{name:"The Seventeen Aurelianos",role:"Colonel Aureliano's bastard sons, all identically named",gen:"War generation",badges:["Ash cross","Collective fate","Ritual massacre"],parents:["aureliano-colonel"],spouses:[],lovers:[],children:[],related:["aureliano-colonel"],summary:"Seventeen sons by seventeen different women, all named Aureliano — all eventually hunted down and killed.",note:"Their repetition literalizes the novel's central theme of doomed cyclical recurrence.",
    notes:{arc:"The sons arrive in Macondo during Carnival, each bearing a different mother's surname but all sharing the name Aureliano. On Ash Wednesday they are all marked with ash crosses. They are subsequently hunted and killed one by one — all except one who escapes into legend — in a coordinated massacre.",themes:"The multiplication of identity into meaninglessness. The repeated name was meant to unify them with their father's legacy; instead it makes them interchangeable and collectively expendable.",watch:"Their mass killing is handled almost in passing, with remarkable narrative flatness. García Márquez refuses to dramatize it. The horror is precisely in the understatement."}},
  "remedios-beauty":{name:"Remedios the Beauty",role:"Granddaughter of Arcadio; a being outside ordinary reality",gen:"Later generation",badges:["Men die nearby","Ascends to heaven","Beyond vanity"],parents:["arcadio","santa-sofia"],spouses:[],lovers:[],children:[],related:["arcadio","santa-sofia"],summary:"Her beauty is a metaphysical force — men fall ill and die in her presence, and she eventually ascends to heaven while folding sheets.",note:"Do not confuse her with Remedios Moscote — same name, entirely different register.",
    notes:{arc:"Entirely without vanity or cruelty — she simply does not register that her presence destroys men. She wanders the house in a sheet because clothes are an incomprehensible convention. She ascends bodily to heaven one afternoon while folding sheets with Fernanda in the garden.",themes:"Beauty as a force outside human moral categories. She is neither saint nor femme fatale — she simply exceeds the world's capacity to process her.",watch:"Note that she causes no intentional harm. Every death in her vicinity is an accident of metaphysical intensity, not will. The social world's inability to leave her alone is what creates the damage."}},
  "jose-arcadio-segundo":{name:"José Arcadio Segundo",role:"Twin; sole witness of the banana massacre",gen:"Later generation",badges:["Massacre survivor","Memory vs erasure","Melquíades' room"],parents:["arcadio","santa-sofia"],spouses:[],lovers:[],children:[],related:["aureliano-segundo","arcadio","santa-sofia"],summary:"Witnesses the mass killing of banana plantation workers — an atrocity subsequently erased from all official record.",note:"His experience is the novel's most direct engagement with Colombian political history.",
    notes:{arc:"Witnesses soldiers massacring banana plantation strikers and escapes by hiding under the corpses. When he returns to Macondo, everyone insists the massacre never happened. He spends the rest of his life in Melquíades' room, eventually passing the key to decoding the manuscripts to the final Aureliano.",themes:"Historical erasure and the politics of memory. His isolation is not the Buendía solitude of obsession — it is the isolation of the man who has seen what the world refuses to remember. Based on the actual 1928 Ciénaga massacre in Colombia.",watch:"Pay careful attention to how systematically the outside world denies his testimony — newspapers, officials, neighbors, family. This is the novel's most politically explicit passage, and one of its most emotionally devastating."}},
  "aureliano-segundo":{name:"Aureliano Segundo",role:"Twin; husband of Fernanda, companion of Petra",gen:"Later generation",badges:["Legendary excess","Two households","Rain and ruin"],parents:["arcadio","santa-sofia"],spouses:["fernanda"],lovers:["petra"],children:["renata","jose-arcadio-later","amaranta-ursula"],related:["fernanda","petra","renata","jose-arcadio-later","amaranta-ursula"],summary:"The jovial twin who leads a life of spectacular excess across two households until the rains destroy everything.",note:"His relationships create another doubled household structure that mirrors the family's broader patterns.",
    notes:{arc:"Legendary for his feats of eating and celebration, he lives between his formal wife Fernanda and his true love Petra Cotes. The decade-long rain strips him of everything. He dies in the same hour as Fernanda, in different parts of the house, and both are buried in the same ceremony.",themes:"Abundance as its own kind of solitude. He is surrounded by food, people, and laughter, yet increasingly isolated from everything that matters. Generosity without depth is still a form of avoidance.",watch:"His raffle schemes to fund Meme's European education are among the novel's funniest and most tragicomic episodes — pure Buendía energy applied to an increasingly hopeless project, refusing to acknowledge that the world is ending."}},
  "fernanda":{name:"Fernanda del Carpio",role:"Aristocratic wife of Aureliano Segundo",gen:"Later generation marriage connection",badges:["Invisible doctors","False grandeur","Self-delusion"],parents:[],spouses:["aureliano-segundo"],lovers:[],children:["renata","jose-arcadio-later","amaranta-ursula"],related:["aureliano-segundo"],summary:"Raised to be the queen of a kingdom that never materialised, she carries an aristocratic fiction into a household that runs on entirely different logic.",note:"She clashes structurally with the Buendía household's organic disorder — and loses, slowly.",
    notes:{arc:"Raised in a highland city to be a queen of a ceremony that never arrived. She conducts a years-long correspondence with invisible doctors who diagnose her remotely by mail. She dies still locked inside her own self-constructed grandeur.",themes:"Class pretension as a form of self-imprisonment. Her identity is entirely a social construction, and when the social world that constructed it collapses, she has no other self to draw on.",watch:"Her unsent letters show exactly how vast the gap between her self-image and reality has grown — and how thoroughly she has chosen the self-image."}},
  "petra":{name:"Petra Cotes",role:"Lover of Aureliano Segundo; abundance personified",gen:"Later generation",badges:["Animal fertility","Loyal companion","Survives the rains"],parents:[],spouses:[],lovers:["aureliano-segundo"],children:[],related:["aureliano-segundo"],summary:"Aureliano Segundo's true companion — her union with him generates magical animal fertility, and her loyalty outlasts everything the rains destroy.",note:"She is the novel's argument that vitality and generosity constitute their own moral order.",
    notes:{arc:"Aureliano Segundo's companion for most of his adult life — never his formal wife, always his genuine partner. The animals on her property multiply supernaturally when she is with Aureliano Segundo. When the rains ruin their fortune, she works herself to exhaustion to support them both.",themes:"Love without institutionalization, abundance without greed. She is perhaps the most straightforwardly life-affirming female character in the novel — clear-eyed about her situation, unbothered by convention, generous without martyrdom.",watch:"García Márquez is explicit that the miraculous animal fertility is contingent on the joy of their union. Vitality, the novel argues, is a shared condition, not an individual property."}},
  "renata":{name:"Renata Remedios (Meme)",role:"Daughter of Aureliano Segundo and Fernanda",gen:"Final generations",badges:["Meme","Yellow butterflies","Permanent silence"],parents:["aureliano-segundo","fernanda"],spouses:[],lovers:["mauricio"],children:["aureliano-babilonia"],related:["mauricio","aureliano-babilonia"],summary:"Known as Meme — her love affair with Mauricio Babilonia ends with his paralysis and her lifelong silence in a convent.",note:"Her silence after her mother's intervention is never psychologically explained — the ambiguity between choice and trauma is deliberate.",
    notes:{arc:"Goes by Meme throughout. Her love affair with the mechanic Mauricio Babilonia — always heralded by yellow butterflies — is the novel's most purely romantic subplot. Fernanda arranges for Mauricio to be shot while climbing to see Meme, paralyzing him for life. Meme is immediately sent to a convent, where she maintains total silence until her death.",themes:"The destruction of eros by class anxiety and maternal control. Fernanda's intervention — motivated entirely by social prejudice about Mauricio's working-class origins — is the novel's most precise act of domestic violence.",watch:"Meme's silence after her mother's action is never explained as breakdown, rage, or grief — it is simply described as a fact. The refusal to psychologize it is one of García Márquez's most powerful narrative choices."}},
  "jose-arcadio-later":{name:"José Arcadio",role:"Son of Aureliano Segundo; failed seminarian",gen:"Final generations",badges:["Rome","Luxury baths","Gothic end"],parents:["aureliano-segundo","fernanda"],spouses:[],lovers:[],children:[],related:["aureliano-segundo","fernanda"],summary:"Sent by Fernanda to Rome to train for the papacy — returns having spent the money on pleasure, and is murdered in his bath.",note:"Distinguish carefully from José Arcadio Buendía (patriarch) and José Arcadio (eldest son).",
    notes:{arc:"Fernanda sends him to Rome, convinced he is destined for the papacy. He returns after her death having spent the seminary money on every luxury. He fills the old house with exquisite objects, takes in local children, and is found drowned in his bath — apparently by those same children.",themes:"Religious vocation hollowed into pure privilege. He represents the final stage of Buendía decay — intellect and physicality both exhausted, replaced by a performance of refinement with nothing behind it.",watch:"His bath is described in obsessive sensory detail. García Márquez uses luxury as a diagnostic sign of moral vacancy throughout the novel, and this scene is the most explicit instance."}},
  "amaranta-ursula":{name:"Amaranta Úrsula",role:"Last vital Buendía; determined to save Macondo",gen:"Final generations",badges:["Returns from Europe","The last energy","Husband on a rope"],parents:["aureliano-segundo","fernanda"],spouses:[],lovers:["aureliano-babilonia"],children:[],related:["aureliano-babilonia"],summary:"Returns from Brussels with enormous vital energy — the last Buendía with genuine will to live — but arrives too late.",note:"Her name combines two earlier poles of the family: Amaranta's passion and refusal, Úrsula's energy and clarity.",
    notes:{arc:"Returns from studying in Europe with her husband Gaston on a playful leash — she literally leads him by a rope. She sets about restoring Macondo with genuine Buendía intensity, unaware that it is dying. Her incestuous relationship with Aureliano Babilonia produces the child with a pig's tail. She dies of hemorrhage after the birth.",themes:"The tragedy of vitality applied to an already-decided fate. She has all the energy of the early Buendías but arrives in the last chapter. Her death fulfills the family's founding curse — and makes the novel's ending feel not like failure but like completion.",watch:"Her husband Gaston is a quietly fascinating peripheral figure — entirely reasonable, entirely outmatched. He retreats to Brussels and writes cheerful letters that Amaranta Úrsula stops opening."}},
  "mauricio":{name:"Mauricio Babilonia",role:"Meme's lover; surrounded by yellow butterflies",gen:"Final generations connection",badges:["Yellow butterflies","Mechanic","Paralyzed by class"],parents:[],spouses:[],lovers:["renata"],children:["aureliano-babilonia"],related:["renata","aureliano-babilonia"],summary:"A mechanic always surrounded by yellow butterflies — his love for Meme is genuine and reciprocal, destroyed by Fernanda's class prejudice.",note:"The butterflies are one of the novel's most famous magical-realist signatures, and one of the few García Márquez never explains.",
    notes:{arc:"Works as a mechanic at the banana company. Yellow butterflies appear before he does and linger after he leaves. His relationship with Meme is warm and reciprocal. Fernanda has him shot while he is climbing to see Meme, paralyzing him permanently. He dies years later in obscurity.",themes:"Working-class desire destroyed by bourgeois prejudice. He is one of the novel's most sympathetic figures precisely because he wants nothing extraordinary — only to be with the person he loves — and this simple want is what kills him.",watch:"The yellow butterflies appear before Mauricio does and stop appearing after he is paralyzed. They are harbingers, not decorations — their absence marks the point at which something has permanently ended."}},
  "aureliano-babilonia":{name:"Aureliano Babilonia",role:"Final Aureliano; reader of the manuscripts",gen:"Final generation",badges:["Sanskrit","Melquíades' manuscripts","Last Buendía"],parents:["renata","mauricio"],spouses:[],lovers:["amaranta-ursula"],children:[],related:["renata","mauricio","amaranta-ursula","melquiades"],summary:"Raised in isolation, teaches himself Sanskrit, and decodes the manuscripts — which describe the entire Buendía history including the moment of his reading.",note:"He is simultaneously the last Buendía, the last reader, and the reader's surrogate at the novel's catastrophic ending.",
    notes:{arc:"Hidden from Fernanda, raised in near-total isolation in Melquíades' room. Teaches himself Sanskrit to read the parchments. When he finally decodes them, he discovers they are a history of the Buendía family written a century earlier, predicting every event precisely — including the moment of his reading. Macondo is destroyed by a biblical wind as he finishes the final page.",themes:"The reader as the last Buendía. His decoding of the manuscripts mirrors the reader's experience of the novel — both arrive at the catastrophic ending at the same moment, both discover they have been reading their own fate.",watch:"The manuscript's final prophecy — that the city of mirrors will be wiped out by wind and exiled from the memory of men — is the novel's last sentence in disguise. García Márquez collapses author, character, and reader into a single moment of annihilation."}},
  "pietro-crespi":{name:"Pietro Crespi",role:"Italian technician; object of the sisters' rivalry",gen:"Romantic connection",badges:["Pianola","Balletic patience","Flower-petal suicide"],parents:[],spouses:[],lovers:["rebeca","amaranta"],children:[],related:["rebeca","amaranta"],summary:"A refined Italian whose courtship of Rebeca is sabotaged by Amaranta, and whose subsequent courtship of Amaranta ends in suicide.",note:"His gentleness makes him incompatible with the Buendía household's emotional extremity.",
    notes:{arc:"Arrives to install a pianola and becomes a social sensation. He courts Rebeca with balletic patience until Amaranta manipulates him away. He redirects his love to Amaranta, who encourages then refuses him. He kills himself surrounded by flower petals and musical instruments.",themes:"European civilization meeting New World appetite for emotional destruction. His tragedy is that he takes social forms — courtship, patience, declaration — at face value, not understanding that in the Buendía house these forms are weapons.",watch:"His suicide is treated by the family as a social inconvenience rather than a tragedy. Only Úrsula genuinely grieves. The speed with which everyone else moves on is quietly appalling."}}
};

const cards=[...document.querySelectorAll('.person')];
const treeEl=document.getElementById('tree');
const canvasEl=document.querySelector('.canvas-wrap');
let svgEl;

// Arrowhead geometry constants (pixels)
const AL=15, AW=14; // length along path, width perpendicular

function initSVG(){
  svgEl=document.createElementNS('http://www.w3.org/2000/svg','svg');
  svgEl.style.cssText='position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none;overflow:visible;z-index:2;';
  treeEl.appendChild(svgEl);
}

function getRect(c){const cr=c.getBoundingClientRect(),tr=treeEl.getBoundingClientRect();return{x:cr.left-tr.left,y:cr.top-tr.top,w:cr.width,h:cr.height};}
function edgePt(r,tx,ty){const cx=r.x+r.w/2,cy=r.y+r.h/2,dx=tx-cx,dy=ty-cy;if(!dx&&!dy)return{x:cx,y:cy};const s=Math.min(r.w/2/Math.abs(dx||.0001),r.h/2/Math.abs(dy||.0001));return{x:cx+dx*s,y:cy+dy*s};}
function makePath(ax,ay,bx,by,i,isAdj){
  if(isAdj)return`M${ax} ${ay} L${bx} ${by}`;
  if(Math.abs(by-ay)<50){const arc=(i%2===0?-1:1)*60,mx=(ax+bx)/2;return`M${ax} ${ay} Q${mx} ${ay+arc} ${bx} ${by}`;}
  const my=(ay+by)/2;return`M${ax} ${ay} C${ax} ${my} ${bx} ${my} ${bx} ${by}`;
}
function clearArrows(){svgEl&&svgEl.querySelectorAll('path').forEach(p=>p.remove());}

function drawArrows(selId){
  clearArrows();
  const sc=cards.find(c=>c.dataset.id===selId);if(!sc)return;
  const p=people[selId],sr=getRect(sc),scx=sr.x+sr.w/2,scy=sr.y+sr.h/2;
  const types=activeFilter?FILTER_TYPES[activeFilter]:REL_TYPES;
  types.forEach(type=>{
    (p[type]||[]).forEach((rid,i)=>{
      const rc=cards.find(c=>c.dataset.id===rid);if(!rc)return;
      const rr=getRect(rc),rcx=rr.x+rr.w/2,rcy=rr.y+rr.h/2;
      const s=edgePt(sr,rcx,rcy),e=edgePt(rr,scx,scy);
      const isSp=type==='spouses';
      const isAdj=Math.abs(s.y-e.y)<20&&Math.abs(s.x-e.x)<80;
      const col=COLORS[type],sw=isSp?'11.4':'4.4',op=isSp?'0.53':'0.62';
      // Build path — shorten endpoint by AL so arrowhead sits outside the stroke
      let pathD;
      if(isAdj){pathD=`M${s.x} ${s.y} L${e.x} ${e.y}`;}
      else if(Math.abs(e.y-s.y)<50){
        const arc=(i%2===0?-1:1)*60,mx=(s.x+e.x)/2;
        if(isSp){pathD=`M${s.x} ${s.y} Q${mx} ${s.y+arc} ${e.x} ${e.y}`;}
        else{const dx=e.x-mx,dy=e.y-(s.y+arc),len=Math.sqrt(dx*dx+dy*dy)||1,ux=dx/len,uy=dy/len;pathD=`M${s.x} ${s.y} Q${mx} ${s.y+arc} ${e.x-ux*AL} ${e.y-uy*AL}`;}
      } else {
        const my=(s.y+e.y)/2,sgn=e.y>my?1:-1;
        pathD=isSp?`M${s.x} ${s.y} C${s.x} ${my} ${e.x} ${my} ${e.x} ${e.y}`:`M${s.x} ${s.y} C${s.x} ${my} ${e.x} ${my} ${e.x} ${e.y-sgn*AL}`;
      }
      const path=document.createElementNS('http://www.w3.org/2000/svg','path');
      path.setAttribute('d',pathD);path.setAttribute('stroke',col);
      path.setAttribute('stroke-width',sw);path.setAttribute('fill','none');
      path.setAttribute('opacity',op);path.setAttribute('stroke-linecap','round');
      svgEl.appendChild(path);
      // Draw arrowhead as a plain polygon — no SVG markers, no coordinate-system confusion
      if(!isSp&&!isAdj){
        let pts;
        if(Math.abs(e.y-s.y)<50){
          // Quadratic: derive approach direction from control point → endpoint
          const arc=(i%2===0?-1:1)*60,mx=(s.x+e.x)/2;
          const dx=e.x-mx,dy=e.y-(s.y+arc),len=Math.sqrt(dx*dx+dy*dy)||1;
          const ux=dx/len,uy=dy/len,px=-uy,py=ux;
          const bx2=e.x-ux*AL,by2=e.y-uy*AL;
          pts=`${bx2+px*AW/2},${by2+py*AW/2} ${e.x},${e.y} ${bx2-px*AW/2},${by2-py*AW/2}`;
        } else {
          // Cubic: always arrives vertically (control pt is directly above/below endpoint)
          const my=(s.y+e.y)/2,sgn=e.y>my?1:-1,by2=e.y-sgn*AL;
          pts=`${e.x-AW/2},${by2} ${e.x+AW/2},${by2} ${e.x},${e.y}`;
        }
        const arrow=document.createElementNS('http://www.w3.org/2000/svg','polygon');
        arrow.setAttribute('points',pts);arrow.setAttribute('fill',col);arrow.setAttribute('opacity',op);
        svgEl.appendChild(arrow);
      }
    });
  });
}

function drawGlobalArrows(types){
  clearArrows();const drawn=new Set();
  const dt=types.includes('children')?types.filter(t=>t!=='parents'):types;
  cards.forEach(card=>{
    const id=card.dataset.id,p=people[id];if(!p)return;
    dt.forEach(type=>{
      (p[type]||[]).forEach((rid,i)=>{
        const key=[id,rid].sort().join('|');if(drawn.has(key))return;drawn.add(key);
        const rc=cards.find(c=>c.dataset.id===rid);if(!rc)return;
        const sr=getRect(card),rr=getRect(rc);
        const s=edgePt(sr,rr.x+rr.w/2,rr.y+rr.h/2),e=edgePt(rr,sr.x+sr.w/2,sr.y+sr.h/2);
        const path=document.createElementNS('http://www.w3.org/2000/svg','path');
        const isSp=type==='spouses';
        const isAdj=Math.abs(s.y-e.y)<20&&Math.abs(s.x-e.x)<80;
        path.setAttribute('d',makePath(s.x,s.y,e.x,e.y,i,isAdj));
        path.setAttribute('stroke',COLORS[type]);path.setAttribute('stroke-width',isSp?'9':'3.6');
        path.setAttribute('fill','none');path.setAttribute('opacity','0.35');
        path.setAttribute('stroke-linecap',isSp?'round':'butt');
        if(!isSp)path.setAttribute('marker-end','url(#arr-'+type+')');
        svgEl.appendChild(path);
      });
    });
  });
}

const SPRING_K=0.10,PAD=14,MAX_ITER=15;
let allFreed=false,simRAF=null,fixedCard=null;
const origGridPos=new Map(),homePos=new Map(),origDOM=new Map();
const titleCardMap=new Map(),origTitleDOM=new Map();

function freeAll(){
  if(allFreed)return;allFreed=true;
  const tr=treeEl.getBoundingClientRect();
  treeEl.style.minHeight=treeEl.scrollHeight+'px';
  const cSnap=new Map(),titles=[...treeEl.querySelectorAll('.gen-title')];
  cards.forEach(c=>{const r=c.getBoundingClientRect();cSnap.set(c,{x:r.left-tr.left,y:r.top-tr.top,w:r.width,h:r.height});origDOM.set(c,{parent:c.parentNode,next:c.nextSibling});});
  const tSnap=new Map();
  titles.forEach(t=>{const r=t.getBoundingClientRect();tSnap.set(t,{x:r.left-tr.left,y:r.top-tr.top});origTitleDOM.set(t,{parent:t.parentNode,next:t.nextSibling});const g=t.closest('.generation');titleCardMap.set(t,g?cards.filter(c=>g.contains(c)):[]);});
  cards.forEach(c=>{const p=cSnap.get(c);origGridPos.set(c,{...p});homePos.set(c,{...p});treeEl.appendChild(c);c.style.cssText=`position:absolute;left:${p.x}px;top:${p.y}px;width:${p.w}px;z-index:10;`;});
  titles.forEach(t=>{const p=tSnap.get(t);treeEl.appendChild(t);t.style.cssText=`position:absolute;left:${p.x}px;top:${p.y}px;white-space:nowrap;width:auto;z-index:5;transition:left .22s ease,top .22s ease;pointer-events:none;`;});
}

function updateTitlePositions(){
  if(!allFreed)return;
  titleCardMap.forEach((gc,title)=>{
    if(!gc.length)return;
    let minX=Infinity,maxX=-Infinity,minY=Infinity;
    gc.forEach(c=>{const x=parseFloat(c.style.left)||0,y=parseFloat(c.style.top)||0,w=parseFloat(c.style.width)||c.offsetWidth;minX=Math.min(minX,x);maxX=Math.max(maxX,x+w);minY=Math.min(minY,y);});
    const tw=title.offsetWidth;
    title.style.left=((minX+maxX)/2-tw/2)+'px';
    title.style.top=Math.max(4,minY-title.offsetHeight-12)+'px';
  });
}

function resolveCollisions(fc){
  const st=cards.map(c=>({c,fixed:c===fc,x:parseFloat(c.style.left)||0,y:parseFloat(c.style.top)||0,w:parseFloat(c.style.width)||c.offsetWidth,h:c.offsetHeight}));
  const n=st.length;
  for(let iter=0;iter<MAX_ITER;iter++){let any=false;for(let i=0;i<n;i++)for(let j=i+1;j<n;j++){const a=st[i],b=st[j];if(a.fixed&&b.fixed)continue;const dx=(b.x+b.w/2)-(a.x+a.w/2),dy=(b.y+b.h/2)-(a.y+a.h/2);const ovX=(a.w+b.w)/2+PAD-Math.abs(dx),ovY=(a.h+b.h)/2+PAD-Math.abs(dy);if(ovX<=0||ovY<=0)continue;any=true;const sx=dx===0?1:Math.sign(dx),sy=dy===0?1:Math.sign(dy);if(ovX<ovY){if(a.fixed)b.x+=sx*ovX;else if(b.fixed)a.x-=sx*ovX;else{a.x-=sx*ovX/2;b.x+=sx*ovX/2;}}else{if(a.fixed)b.y+=sy*ovY;else if(b.fixed)a.y-=sy*ovY;else{a.y-=sy*ovY/2;b.y+=sy*ovY/2;}}}if(!any)break;}
  st.forEach(({c,x,y,fixed})=>{if(!fixed){c.style.left=x+'px';c.style.top=y+'px';}});
}

function simStep(){
  let max=0;
  cards.forEach(c=>{if(c===fixedCard)return;const h=homePos.get(c);if(!h)return;const cx=parseFloat(c.style.left),cy=parseFloat(c.style.top);const dx=(h.x-cx)*SPRING_K,dy=(h.y-cy)*SPRING_K;c.style.left=(cx+dx)+'px';c.style.top=(cy+dy)+'px';max=Math.max(max,Math.abs(dx),Math.abs(dy));});
  resolveCollisions(fixedCard);return max;
}

function scheduleFrame(){
  if(simRAF)return;
  simRAF=requestAnimationFrame(()=>{simRAF=null;if(!allFreed)return;const d=simStep();updateTitlePositions();const sel=document.querySelector('.person.selected');if(sel)drawArrows(sel.dataset.id);if(!fixedCard&&d>0.3)scheduleFrame();});
}

// Canvas pan — works on .canvas-wrap which no longer contains the legend
canvasEl.addEventListener('mousedown',e=>{
  if(e.button!==0||e.target.closest('.person'))return;
  e.preventDefault();canvasEl.classList.add('panning');
  const sx=e.clientX+canvasEl.scrollLeft,sy=e.clientY+canvasEl.scrollTop;
  const mm=me=>{canvasEl.scrollLeft=sx-me.clientX;canvasEl.scrollTop=sy-me.clientY;};
  const mu=()=>{canvasEl.classList.remove('panning');document.removeEventListener('mousemove',mm);document.removeEventListener('mouseup',mu);};
  document.addEventListener('mousemove',mm);document.addEventListener('mouseup',mu);
});

const popupEl=document.getElementById('char-popup');
const backdropEl=document.getElementById('popup-backdrop');

function openPopup(id){
  const p=people[id];if(!p||!p.notes)return;
  selectPerson(id);
  const gc=GEN_COLORS[p.gen]||'rgba(255,255,255,.3)';
  const av=document.getElementById('popup-avatar');
  av.textContent=initials(p.name);
  av.style.cssText=`background:${gc}20;border-color:${gc}60;color:${gc};`;
  document.getElementById('popup-name').textContent=p.name;
  document.getElementById('popup-role').textContent=p.role;
  const genEl=document.getElementById('popup-gen');
  genEl.className='popup-gen';genEl.textContent=p.gen;
  genEl.style.cssText=`background:${gc}18;border:1px solid ${gc}44;color:${gc};`;
  const rels=[popupRelNav('Spouses',p.spouses,COLORS.spouses),popupRelNav('Parents',p.parents,COLORS.parents),popupRelNav('Children',p.children,COLORS.children),popupRelNav('Lovers',p.lovers,COLORS.lovers)].filter(Boolean).join('');
  document.getElementById('popup-body').innerHTML=`
    <div class="popup-section arc"><h4>Arc in the novel</h4><p>${p.notes.arc}</p></div>
    <div class="popup-section themes-sec"><h4>Themes &amp; significance</h4><p>${p.notes.themes}</p></div>
    <div class="popup-section watch"><h4>What to watch for</h4><p>${p.notes.watch}</p></div>
    ${rels?`<div class="popup-section rels"><h4>Relationships</h4>${rels}</div>`:''}`;
  popupEl.classList.remove('hidden');backdropEl.classList.remove('hidden');
}

function popupRelNav(label,ids,color){
  const valid=(ids||[]).filter(id=>people[id]&&people[id].notes);
  if(!valid.length)return'';
  return`<div class="popup-rel-group">
    <span class="popup-rel-label" style="color:${color};">${label}</span>
    ${valid.map(id=>`<button class="popup-nav-btn" onclick="openPopup('${id}')" style="background:${color}18;border:1px solid ${color}44;">${people[id].name}</button>`).join('')}
  </div>`;
}

function closePopup(){popupEl.classList.add('hidden');backdropEl.classList.add('hidden');}
document.getElementById('popup-close').addEventListener('click',closePopup);
backdropEl.addEventListener('click',closePopup);

function bindCardDrag(card){
  const onDown=e=>{
    if(e.button!==0&&!e.touches)return;e.preventDefault();
    const isTouch=!!e.touches;
    const cr=card.getBoundingClientRect();
    const startCX=isTouch?e.touches[0].clientX:e.clientX;
    const startCY=isTouch?e.touches[0].clientY:e.clientY;
    const offX=startCX-cr.left,offY=startCY-cr.top;
    let started=false;
    const onMove=me=>{
      const cx=me.touches?me.touches[0].clientX:me.clientX;
      const cy=me.touches?me.touches[0].clientY:me.clientY;
      if(!started){if(Math.hypot(cx-startCX,cy-startCY)<5)return;started=true;freeAll();fixedCard=card;card.classList.add('dragging');card.style.zIndex='50';}
      me.preventDefault();
      const tr=treeEl.getBoundingClientRect();
      card.style.left=(cx-tr.left-offX)+'px';card.style.top=(cy-tr.top-offY)+'px';scheduleFrame();
    };
    const onUp=()=>{
      document.removeEventListener('mousemove',onMove);document.removeEventListener('mouseup',onUp);
      document.removeEventListener('touchmove',onMove);document.removeEventListener('touchend',onUp);
      if(!started){if(card.classList.contains('selected'))resetView();else selectPerson(card.dataset.id);return;}
      card.classList.remove('dragging');card.style.zIndex='10';
      const h=homePos.get(card)||{};homePos.set(card,{...h,x:parseFloat(card.style.left),y:parseFloat(card.style.top)});
      fixedCard=null;scheduleFrame();
    };
    document.addEventListener('mousemove',onMove);document.addEventListener('mouseup',onUp);
    document.addEventListener('touchmove',onMove,{passive:false});document.addEventListener('touchend',onUp);
  };
  card.addEventListener('mousedown',onDown);card.addEventListener('touchstart',onDown,{passive:false});
}

function resetLayout(){
  if(!allFreed)return;if(simRAF){cancelAnimationFrame(simRAF);simRAF=null;}fixedCard=null;
  cards.forEach(c=>{const p=origGridPos.get(c);if(p)homePos.set(c,{...p});});scheduleFrame();
  setTimeout(()=>{
    if(simRAF){cancelAnimationFrame(simRAF);simRAF=null;}
    cards.forEach(c=>{['position','left','top','width','zIndex','transition'].forEach(s=>c.style[s]='');const{parent,next}=origDOM.get(c)||{};if(!parent)return;if(next&&next.parentNode===parent)parent.insertBefore(c,next);else parent.appendChild(c);});
    origTitleDOM.forEach(({parent,next},t)=>{['position','left','top','width','zIndex','transition','whiteSpace','pointerEvents'].forEach(s=>t.style[s]='');if(next&&next.parentNode===parent)parent.insertBefore(t,next);else parent.appendChild(t);});
    treeEl.style.minHeight='';origGridPos.clear();homePos.clear();origDOM.clear();titleCardMap.clear();origTitleDOM.clear();allFreed=false;clearArrows();
    const sel=document.querySelector('.person.selected');if(sel)setTimeout(()=>drawArrows(sel.dataset.id),60);
  },600);
}

function initials(name){return name.split(' ').filter(w=>w.length>2&&!/^(de|del|la|el|y)$/i.test(w)).slice(0,2).map(w=>w[0].toUpperCase()).join('')||name[0];}
const noteSVG=`<svg viewBox="0 0 16 16" fill="currentColor"><path d="M3 2a1 1 0 011-1h5.586L13 4.414V14a1 1 0 01-1 1H4a1 1 0 01-1-1V2zm6 0v3.5h3.5L9 2zM5 7.5h6v1H5v-1zm0 2.5h6v1H5v-1zm0 2.5h3.5v1H5v-1z"/></svg>`;

function renderCards(){
  cards.forEach(card=>{
    const id=card.dataset.id,p=people[id];if(!p)return;
    const gc=GEN_COLORS[p.gen]||'rgba(255,255,255,.25)';
    card.innerHTML=`
      <div class="card-top">
        <div class="avatar-init" style="background:${gc}22;border-color:${gc}55;color:${gc};">${initials(p.name)}</div>
        <div class="card-info"><div class="name">${p.name}</div><div class="role">${p.role}</div></div>
        ${p.notes?`<button class="note-btn" title="Character notes">${noteSVG}</button>`:''}
      </div>
      <div class="badges">${p.badges.map(b=>`<span class="badge">${b}</span>`).join('')}</div>`;
    if(p.notes){
      const btn=card.querySelector('.note-btn');
      btn.addEventListener('mousedown',e=>e.stopPropagation());
      btn.addEventListener('touchstart',e=>e.stopPropagation(),{passive:true});
      btn.addEventListener('click',e=>{e.stopPropagation();openPopup(id);});
    }
    bindCardDrag(card);
  });
}

function selectPerson(id){
  const p=people[id];if(!p)return;
  // Build a map of related-id → border color by relationship type
  const relColors=new Map();
  [['spouses',COLORS.spouses],['parents',COLORS.parents],['children',COLORS.children],['lovers',COLORS.lovers]].forEach(([k,col])=>{
    (p[k]||[]).forEach(rid=>{if(!relColors.has(rid))relColors.set(rid,col);});
  });
  (p.related||[]).forEach(rid=>{if(!relColors.has(rid))relColors.set(rid,'rgba(138,180,255,.8)');});
  cards.forEach(c=>{
    const cid=c.dataset.id,isSel=cid===id,isRel=relColors.has(cid)&&!isSel;
    c.classList.toggle('selected',isSel);c.classList.toggle('related',isRel);c.classList.toggle('dim',!isSel&&!isRel);
    if(isSel){c.style.border='2px solid rgba(128,255,176,.8)';c.style.boxShadow='0 0 0 1px rgba(128,255,176,.3),0 16px 40px rgba(0,0,0,.28)';}
    else if(isRel){const col=relColors.get(cid);c.style.border=`2px solid ${col}`;c.style.boxShadow=`0 0 0 1px ${col}40,0 10px 28px rgba(0,0,0,.2)`;}
    else{c.style.border='';c.style.boxShadow='';}
  });
  drawArrows(id);
}

function resetView(){
  if(!popupEl.classList.contains('hidden')){closePopup();return;}
  activeFilter=null;activeTheme=null;
  document.querySelectorAll('.filter-btn').forEach(b=>{b.classList.remove('active');b.style.cssText='';});
  document.querySelectorAll('.theme-btn').forEach(b=>{b.classList.remove('active');b.style.cssText='';});
  document.getElementById('search').value='';
  cards.forEach(c=>{c.classList.remove('selected','related','dim');c.style.border='';c.style.boxShadow='';});
  clearArrows();
}

function applyFilter(key){
  if(activeTheme){activeTheme=null;document.querySelectorAll('.theme-btn').forEach(b=>{b.classList.remove('active');b.style.cssText='';});}
  const off=activeFilter===key;activeFilter=off?null:key;
  document.querySelectorAll('.filter-btn').forEach(b=>{const on=b.dataset.filter===activeFilter;b.classList.toggle('active',on);b.style.cssText=on?'background:rgba(255,255,255,.13);border-color:rgba(255,255,255,.32);':'';});
  if(!activeFilter){cards.forEach(c=>c.classList.remove('dim'));const sel=document.querySelector('.person.selected');sel?drawArrows(sel.dataset.id):clearArrows();return;}
  const types=FILTER_TYPES[activeFilter];
  const rel=new Set();cards.forEach(c=>{const id=c.dataset.id,p=people[id];if(!p)return;if(types.some(t=>(p[t]||[]).length>0)){rel.add(id);types.forEach(t=>(p[t]||[]).forEach(rid=>rel.add(rid)));}});
  cards.forEach(c=>c.classList.toggle('dim',!rel.has(c.dataset.id)));
  const sel=document.querySelector('.person.selected');sel?drawArrows(sel.dataset.id):drawGlobalArrows(types);
}

function applyTheme(key){
  if(activeFilter){activeFilter=null;document.querySelectorAll('.filter-btn').forEach(b=>{b.classList.remove('active');b.style.cssText='';});}
  const off=activeTheme===key;activeTheme=off?null:key;
  document.querySelectorAll('.theme-btn').forEach(b=>{const t=THEMES[b.dataset.theme],on=b.dataset.theme===activeTheme;b.classList.toggle('active',on);b.style.cssText=on?`background:${t.col}18;border-color:${t.col}55;color:${t.col};`:'';});
  if(!activeTheme){cards.forEach(c=>c.classList.remove('dim'));const sel=document.querySelector('.person.selected');sel?drawArrows(sel.dataset.id):clearArrows();return;}
  const t=THEMES[activeTheme];
  cards.forEach(c=>c.classList.toggle('dim',!t.ids.has(c.dataset.id)));
  const sel=document.querySelector('.person.selected');sel?drawArrows(sel.dataset.id):clearArrows();
}

document.querySelectorAll('.filter-btn').forEach(b=>b.addEventListener('click',()=>applyFilter(b.dataset.filter)));
document.querySelectorAll('.theme-btn').forEach(b=>b.addEventListener('click',()=>applyTheme(b.dataset.theme)));
document.getElementById('resetLayoutBtn').addEventListener('click',resetLayout);

const deaccent=s=>s.normalize('NFD').replace(/[\u0300-\u036f]/g,'').toLowerCase();
function lev(a,b){const m=a.length,n=b.length;if(!m)return n;if(!n)return m;const row=Array.from({length:n+1},(_,i)=>i);for(let i=1;i<=m;i++){let p=i;for(let j=1;j<=n;j++){const v=a[i-1]===b[j-1]?row[j-1]:1+Math.min(row[j-1],row[j],p);row[j-1]=p;p=v;}row[n]=p;}return row[n];}
function matchScore(q,p){if(!q)return 1;const name=deaccent(p.name),hay=deaccent(`${p.name} ${p.role} ${p.badges.join(' ')}`);if(hay.includes(q))return 1;if(q.length<=2)return name.split(/\s+/).some(t=>t.startsWith(q))?1:0;const qt=q.split(/\s+/).filter(Boolean),nt=name.split(/\s+/).filter(Boolean);let sum=0;for(const q2 of qt){let best=0;for(const n2 of nt){if(n2.startsWith(q2)){best=1;break;}const s=1-lev(q2,n2)/Math.max(q2.length,n2.length);if(s>best)best=s;}sum+=best;}return sum/qt.length;}
document.getElementById('search').addEventListener('input',e=>{const q=deaccent(e.target.value.trim());if(!q){cards.forEach(c=>c.classList.remove('dim'));return;}cards.forEach(c=>{const p=people[c.dataset.id];if(!p)return;c.classList.toggle('dim',matchScore(q,p)<0.65);});});
document.addEventListener('keydown',e=>{if(e.key==='Escape')resetView();});
window.addEventListener('resize',()=>{const s=document.querySelector('.person.selected');if(s)drawArrows(s.dataset.id);});
window.openPopup=openPopup;
initSVG();renderCards();
</script>
</body>
</html>